[segmentation]
# Per-series segmentation parameters for dub1

# --- Log Extraction ---
min_log_area = 127000
log_close_kernel_size = 0

# --- Crust/Bark Segmentation ---
crust_alpha = 1.55
crust_beta = -60
crust_wood_thresh = 200
crust_wood_close_kernel_size = 4
crust_connect_kernel_size = 4
crust_sobel_kernel_size = 29
crust_add_kernel_size = 3
crust_max_edge_distance_ratio = 0.22
crust_max_edge_distance_px = 0

# --- Knot (Suk) Detection ---
suk_intensity_threshold = 220
suk_min_area = 250
suk_gauss_kernel_size = 5

# --- Decay/Rot (Hniloba) Detection ---
hniloba_min_area = 0
hniloba_lower_threshold = 70
hniloba_upper_threshold = 255

# --- Background Cleaning ---
bg_close_kernel_size = 17

# --- Crack Detection ---
crack_threshold = 100
crack_edge_exclude_kernel = 16
crack_crust_exclude_kernel = 7
crack_max_aspect_ratio = 0.5
crack_max_roundness = 0.5
crack_min_area = 1
crack_crust_add_kernel_size = 16
crack_sobel_kernel_size = 7
crack_gauss_kernel_size = 3
