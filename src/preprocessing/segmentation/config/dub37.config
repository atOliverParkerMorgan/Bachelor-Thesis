[segmentation]
# Per-series segmentation parameters for dub4

# --- Log Extraction ---
min_log_area = 127000
log_close_kernel_size = 11

# --- Crust/Bark Segmentation ---
crust_alpha = 1.45
crust_beta = -40
crust_wood_thresh = 0
crust_wood_close_kernel_size = 7
crust_connect_kernel_size = 5
crust_sobel_kernel_size = 0
crust_add_kernel_size = 0
crust_max_edge_distance_ratio = 0.22
crust_max_edge_distance_px = 0

# --- Knot (Suk) Detection ---
suk_intensity_threshold = 220
suk_min_area = 250
suk_gauss_kernel_size = 5

# --- Decay/Rot (Hniloba) Detection ---
hniloba_min_area = 0
hniloba_lower_threshold = 70
hniloba_upper_threshold = 255

# --- Background Cleaning ---
bg_close_kernel_size = 25
# --- Crack Detection ---
crack_threshold = 109
crack_edge_exclude_kernel = 16
crack_crust_exclude_kernel = 7
crack_crust_add_kernel_size = 0
crack_min_area = 8 
crack_max_aspect_ratio = 0.5
crack_max_roundness = 0.9
crack_sobel_kernel_size = 7
crack_gauss_kernel_size = 7