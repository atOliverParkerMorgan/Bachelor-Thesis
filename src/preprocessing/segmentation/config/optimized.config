[segmentation]
# ===================================================================
# OPTIMIZED CONFIGURATION FOR HIGH-RESOLUTION CT LOG SCANS
# ===================================================================

# --- Log Extraction Parameters ---
# Minimum area (in pixels) for the main log contour
# Filters out noise and small objects
min_log_area = 120000

# Morphological closing kernel size for log mask
# 0 = no closing, larger values fill gaps in the log boundary
log_close_kernel_size = 3


# --- Crust/Bark Segmentation (Grayscale-based) ---
# Contrast adjustment applied before thresholding
crust_alpha = 1.45
crust_beta = -50

# Threshold for separating solid inner wood from crust
crust_wood_thresh = 220

# Closing kernel for solid wood mask cleanup
crust_wood_close_kernel_size = 7

# Closing kernel to connect crust regions
crust_connect_kernel_size = 5

# Keep bark only near log boundary:
# ratio = fraction of max inward distance from edge (0-1)
crust_max_edge_distance_ratio = 0.22
# absolute cap in pixels (0 = disabled)
crust_max_edge_distance_px = 0


# --- Knot (Suk) Detection ---
# Intensity threshold for detecting bright knots (0-255)
# Higher values = only very bright regions detected
suk_intensity_threshold = 225

# Minimum area (pixels) for valid knot regions
# Filters out small bright artifacts
suk_min_area = 150

# Gaussian blur kernel for knot detection preprocessing (must be odd)
# Reduces noise before thresholding
suk_gauss_kernel_size = 5


# --- Decay/Rot (Hniloba) Detection ---
# Minimum area (pixels) for decay regions
# 0 = detect all sizes, larger values filter small areas
hniloba_min_area = 50

# Intensity thresholds for detecting decay within knots
# Decay typically appears as darker regions
hniloba_lower_threshold = 65
hniloba_upper_threshold = 255


# --- Background Cleaning ---
# Morphological closing kernel for background mask
# Fills gaps while preserving the central log hole
bg_close_kernel_size = 17


# --- Crack Detection ---
# Gradient threshold for detecting crack edges
crack_threshold = 109

# Kernel size for dilating edge mask to exclude log outline
crack_edge_exclude_kernel = 16

# Kernel size for dilating the bark (kura) mask to exclude bark-adjacent edges
crack_crust_exclude_kernel = 7

# Kernel size for adding edge-derived crust back into final bark mask
crack_crust_add_kernel_size = 8

# Minimum area (pixels) for valid crack regions
crack_min_area = 8

# Maximum aspect ratio for crack detection (width/height)
# Lower values detect more elongated shapes
crack_max_aspect_ratio = 0.5

# Maximum roundness for crack detection
# Lower values exclude circular shapes
crack_max_roundness = 0.9

# Sobel kernel size for gradient computation
crack_sobel_kernel_size = 7

# Gaussian blur kernel size for gradient smoothing
crack_gauss_kernel_size = 7


